{
  "name": "graphviz",
  "version": "0.1.1",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tauri:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "tauri:build": "tauri build",
    "tauri:android:init": "tauri android init --ci --skip-targets-install",
    "tauri:android:build": "tauri android build --ci --apk --aab --split-per-abi",
    "check": "bun run lint && bun run build && bun run tauri:check",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css}\"",
    "upgrade": "bunx --bun ncu -u && bun install",
    "shadcn": "bunx --bun shadcn@latest add",
    "push": "git add . && git commit -m \"chore update\" && git push",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "@tauri-apps/cli": "^2"
  }
}
